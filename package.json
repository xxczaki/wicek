{
  "name": "wicek",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "build": "node esbuild.js",
    "dev": "node esbuild.js && node --env-file=.env dist/index.js | pino-pretty",
    "lint": "biome check --write ./src",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.89",
    "discord.js": "^14.26.2",
    "node-cron": "^3.0.3",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^24.0.0",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.28.0",
    "esbuild-plugin-pino": "2.3.3",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@anthropic-ai/claude-code"]
  }
}
